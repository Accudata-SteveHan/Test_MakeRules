### 1.3 具體範例

#### 1.3.1 正確做法：業務驗證返回 Result

```csharp
public async Task<Result<OrderDto>> CreateOrderAsync(CreateOrderRequest request)
{
    // 1. 驗證輸入（業務邏輯，不拋例外）
    var validationResult = ValidateOrderRequest(request);
    if (!validationResult.IsSuccess)
    {
        return validationResult;  // 回傳 Result，不拋例外
    }

    try
    {
        // 2. 執行業務邏輯
        var order = new Order(request.CustomerId, request.Items);
        
        // 3. 持久化
        await _orderRepository.AddAsync(order);
        await _unitOfWork.SaveChangesAsync();

        return Result<OrderDto>.Success(order.ToDto());
    }
    catch (DbUpdateException ex)
    {
        // 捕捉資料庫例外，轉換為結構化錯誤
        _logger.LogError(ex, "Failed to create order: database error");
        return Result<OrderDto>.Error(
            ErrorCode.SYS_DATABASE_QUERY_ERROR,
            "Order creation failed due to system error"
        );
    }
    catch (Exception ex)
    {
        // 未預期的例外，記錄並回傳通用錯誤
        _logger.LogCritical(ex, "Unexpected error in CreateOrderAsync");
        return Result<OrderDto>.Error(
            ErrorCode.SYS_INTERNAL_ERROR,
            "An unexpected error occurred"
        );
    }
}

private Result<OrderDto> ValidateOrderRequest(CreateOrderRequest request)
{
    var errors = new Dictionary<string, string>();
    
    if (string.IsNullOrWhiteSpace(request.CustomerId))
    {
        errors["customerId"] = "Customer ID is required";
    }
    
    if (request.Items == null || request.Items.Count == 0)
    {
        errors["items"] = "At least one item is required";
    }
    
    if (errors.Count > 0)
    {
        return Result<OrderDto>.Error(
            ErrorCode.BIZ_VALIDATION_REQUIRED_FIELD,
            "Validation failed",
            details: errors
        );
    }
    
    return Result<OrderDto>.Success(null);
}
```

#### 1.3.2 錯誤做法：空 catch、吞例外

```csharp
// ❌ 錯誤做法 1：空 catch
try
{
    await _orderRepository.SaveAsync(order);
}
catch (DbUpdateException) { }  // 吞掉例外，無法追蹤！

// ❌ 錯誤做法 2：捕捉所有例外但無處理
try
{
    await _orderRepository.SaveAsync(order);
}
catch (Exception) { }  // 同樣隱藏故障

// ❌ 錯誤做法 3：捕捉例外後什麼都不做
try
{
    await _orderRepository.SaveAsync(order);
}
catch (DbUpdateException ex)
{
    // 沒有記錄、沒有處理，直接跳過
}
```

#### 1.3.3 正確做法：捕捉例外並正確處理

```csharp
// ✅ 正確做法 1：捕捉特定例外並記錄
try
{
    await _orderRepository.SaveAsync(order);
}
catch (DbUpdateException ex)
{
    _logger.LogError(ex, "Database update failed for order {OrderId}", order.Id);
    throw;  // 重新拋出供上層處理
}

// ✅ 正確做法 2：捕捉並轉換為結構化 Result
try
{
    await _orderRepository.SaveAsync(order);
    return Result<OrderDto>.Success(order.ToDto());
}
catch (DbUpdateException ex)
{
    _logger.LogError(ex, "Database error");
    return Result<OrderDto>.Error(
        ErrorCode.SYS_DATABASE_QUERY_ERROR,
        "Failed to save order"
    );
}

// ✅ 正確做法 3：捕捉並實施恢復策略（重試）
int retryCount = 0;
const int maxRetries = 3;

while (retryCount < maxRetries)
{
    try
    {
        await _orderRepository.SaveAsync(order);
        break;  // 成功，跳出迴圈
    }
    catch (DbUpdateException ex) when (retryCount < maxRetries - 1)
    {
        retryCount++;
        _logger.LogWarning(ex, "Retry {RetryCount}/{MaxRetries} for order save", retryCount, maxRetries);
        await Task.Delay(TimeSpan.FromSeconds(Math.Pow(2, retryCount)));  // 指數退避
    }
    catch (DbUpdateException ex)
    {
        _logger.LogError(ex, "Failed to save order after {Retries} retries", maxRetries);
        throw;
    }
}
```

