// 程式碼使用
public class OrderService
{
    private readonly ILogger<OrderService> _logger;

    public OrderService(ILogger<OrderService> logger)
    {
        _logger = logger;
    }

    public async Task<Result<OrderDto>> CreateOrderAsync(CreateOrderRequest request)
    {
        var correlationId = HttpContext.TraceIdentifier;
        var userId = _currentUser.Id;
        
        using (_logger.BeginScope(new Dictionary<string, object>
        {
            { "CorrelationId", correlationId },
            { "UserId", userId },
            { "Module", nameof(OrderService) },
            { "Action", nameof(CreateOrderAsync) }
        }))
        {
            var stopwatch = Stopwatch.StartNew();
            
            try
            {
                _logger.LogInformation("Creating order for customer {CustomerId}", request.CustomerId);
                
                var order = new Order(request.CustomerId, request.Items);
                await _orderRepository.AddAsync(order);
                await _unitOfWork.SaveChangesAsync();
                
                stopwatch.Stop();
                _logger.LogInformation(
                    "Order {OrderId} created successfully in {ElapsedMs}ms",
                    order.Id,
                    stopwatch.ElapsedMilliseconds
                );
                
                return Result<OrderDto>.Success(order.ToDto());
            }
            catch (DbUpdateException ex)
            {
                stopwatch.Stop();
                _logger.LogError(
                    ex,
                    "Failed to create order for customer {CustomerId} after {ElapsedMs}ms. ErrorCode: {ErrorCode}",
                    request.CustomerId,
                    stopwatch.ElapsedMilliseconds,
                    ErrorCode.SYS_DATABASE_QUERY_ERROR
                );
                
                return Result<OrderDto>.Error(
                    ErrorCode.SYS_DATABASE_QUERY_ERROR,
                    "Order creation failed"
                );
            }
            catch (Exception ex)
            {
                stopwatch.Stop();
                _logger.LogCritical(
                    ex,
                    "Unexpected error creating order after {ElapsedMs}ms",
                    stopwatch.ElapsedMilliseconds
                );
                
                return Result<OrderDto>.Error(
                    ErrorCode.SYS_INTERNAL_ERROR,
                    "An unexpected error occurred"
                );
            }
        }
    }
}
```

